      {
        "id": 8, "type": "table", "title": "Recent Tickets",
        "gridPos": { "h": 10, "w": 24, "x": 0, "y": 30 },
        "datasource": { "type": "mysql", "uid": "ffkjpqscw5j40f" },
        "options": {
          "cellHeight": "sm", "showHeader": true,
          "footer": { "show": false, "reducer": ["sum"] }
        },
        "fieldConfig": {
          "defaults": {
            "custom": { "align": "left", "cellOptions": { "type": "auto" }, "inspect": false }
          },
          "overrides": [
            {
              "matcher": { "id": "byName", "options": "status" },
              "properties": [{
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text",
                  "applyToRow": false
                }
              },{
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "Open":     { "color": "orange", "index": 0 } } },
                  { "type": "value", "options": { "Replied":  { "color": "yellow", "index": 1 } } },
                  { "type": "value", "options": { "Resolved": { "color": "green",  "index": 2 } } },
                  { "type": "value", "options": { "Closed":   { "color": "blue",   "index": 3 } } }
                ]
              }]
            },
            {
              "matcher": { "id": "byName", "options": "priority" },
              "properties": [{
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "Urgent": { "color": "red",    "index": 0 } } },
                  { "type": "value", "options": { "High":   { "color": "orange", "index": 1 } } },
                  { "type": "value", "options": { "Medium": { "color": "yellow", "index": 2 } } },
                  { "type": "value", "options": { "Low":    { "color": "green",  "index": 3 } } }
                ]
              }]
            }
          ]
        },
        "targets": [{
          "datasource": { "type": "mysql", "uid": "ffkjpqscw5j40f" },
          "editorMode": "code", "format": "table", "rawQuery": true,
          "rawSql": "SELECT name AS `#`, subject AS `Subject`, COALESCE(status,'Unknown') AS `status`, COALESCE(priority,'Unknown') AS `priority`, COALESCE(ticket_type,'—') AS `type`, DATE_FORMAT(creation,'%Y-%m-%d %H:%i') AS `Created`, DATE_FORMAT(modified,'%Y-%m-%d %H:%i') AS `Last Updated` FROM `tabHD Ticket` ORDER BY creation DESC LIMIT 25;"
        }]
      },

      { "id": 103, "type": "text", "title": "",
