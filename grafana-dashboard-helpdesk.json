          "defaults": {
            "color": { "mode": "palette-classic" },
            "custom": { "fillOpacity": 80, "lineWidth": 1 }
          }
        },
        "targets": [{
          "datasource": { "type": "mysql", "uid": "ffkjpqscw5j40f" },
          "editorMode": "code", "format": "table", "rawQuery": true,
          "rawSql": "SELECT COALESCE(priority,'Unknown') AS priority, COUNT(*) AS count FROM `tabHD Ticket` WHERE status NOT IN ('Closed','Resolved') GROUP BY priority ORDER BY FIELD(priority,'Urgent','High','Medium','Low','Unknown');"
        }]
      },

      {
        "id": 15, "type": "bargauge", "title": "Tickets by Type",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
