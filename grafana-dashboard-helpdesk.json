      {
        "id": 14, "type": "stat", "title": "Resolution Rate",
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 6 },
        "datasource": { "type": "mysql", "uid": "ffkjpqscw5j40f" },
        "options": {
          "colorMode": "background", "graphMode": "none",
          "justifyMode": "center", "textMode": "auto",
          "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "red", "value": 0 },
                { "color": "yellow", "value": 70 },
                { "color": "green", "value": 85 }
              ]
            },
            "color": { "mode": "thresholds" }
          }
        },
        "targets": [{
          "datasource": { "type": "mysql", "uid": "ffkjpqscw5j40f" },
          "editorMode": "code", "format": "table", "rawQuery": true,
          "rawSql": "SELECT ROUND(100.0 * SUM(CASE WHEN status IN ('Resolved','Closed') THEN 1 ELSE 0 END) / COUNT(*), 1) AS rate FROM `tabHD Ticket`;"
        }]
      },

      { "id": 101, "type": "text", "title": "",
        "gridPos": { "h": 2, "w": 24, "x": 0, "y": 10 },
        "options": {
          "mode": "markdown",
          "content": "## 📊 Trends & Distribution"
        }
      },

      {
        "id": 7, "type": "timeseries", "title": "Tickets Created Per Day (Last 30 Days)",
        "gridPos": { "h": 8, "w": 16, "x": 0, "y": 12 },
        "datasource": { "type": "mysql", "uid": "ffkjpqscw5j40f" },
        "options": {
          "legend": { "calcs": ["sum","max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
          "tooltip": { "mode": "single", "sort": "none" }
        },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "fixed", "fixedColor": "blue" },
            "custom": {
              "drawStyle": "bars", "barAlignment": 0, "barWidthFactor": 0.6,
              "fillOpacity": 80, "lineWidth": 1,
              "gradientMode": "none", "pointSize": 5,
              "showPoints": "never", "spanNulls": false,
              "stacking": { "group": "A", "mode": "none" },
              "thresholdsStyle": { "mode": "off" }
            },
            "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }] }
          }
        },
        "targets": [{
          "datasource": { "type": "mysql", "uid": "ffkjpqscw5j40f" },
          "editorMode": "code", "format": "time_series", "rawQuery": true,
          "rawSql": "SELECT DATE_FORMAT(DATE(creation), '%Y-%m-%dT%H:%i:%sZ') AS time, COUNT(*) AS tickets_created FROM `tabHD Ticket` WHERE creation >= DATE_SUB(CURDATE(), INTERVAL 30 DAY) GROUP BY DATE(creation) ORDER BY DATE(creation);"
        }]
      },

      {
        "id": 5, "type": "piechart", "title": "Status Breakdown",
        "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
        "datasource": { "type": "mysql", "uid": "ffkjpqscw5j40f" },
        "options": {
          "pieType": "donut",
          "displayLabels": ["name","percent"],
          "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "values": ["value","percent"] },
          "tooltip": { "mode": "single", "sort": "none" }
        },
        "fieldConfig": {
          "defaults": { "color": { "mode": "palette-classic" } }
        },
        "targets": [{
          "datasource": { "type": "mysql", "uid": "ffkjpqscw5j40f" },
          "editorMode": "code", "format": "table", "rawQuery": true,
          "rawSql": "SELECT COALESCE(status,'Unknown') AS status, COUNT(*) AS count FROM `tabHD Ticket` GROUP BY status ORDER BY count DESC;"
        }]
      },

      {
        "id": 6, "type": "barchart", "title": "Open Tickets by Priority",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
        "datasource": { "type": "mysql", "uid": "ffkjpqscw5j40f" },
        "options": {
          "orientation": "horizontal",
          "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false },
          "tooltip": { "mode": "single", "sort": "none" },
