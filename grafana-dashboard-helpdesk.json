      {
        "id": 9, "type": "stat", "title": "ERPNext Uptime",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 42 },
        "datasource": { "type": "prometheus", "uid": "efkjouds5aolcc" },
        "options": {
